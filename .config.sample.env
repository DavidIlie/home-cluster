# The repo this is from
export BOOTSTRAP_GIT_REPOSITORY="https://github.com/davidilie/home-cluster"

# To enable Flux to update your cluster on `git push` set the following to one of:
# `generated` - this will generate a token and print it in the logs
export BOOTSTRAP_FLUX_GITHUB_WEBHOOK_SECRET=""

# The Weave GitOps dashboard admin password
# `generated` - this will generate a token and print it in the logs
export BOOTSTRAP_WEAVE_GITOPS_ADMIN_PASSWORD=""

# Choose one of your cloudflare domains
export BOOTSTRAP_CLOUDFLARE_DOMAIN="davidapps.dev"
export BOOTSTRAP_CLOUDFLARE_EMAIL="david@davidilie.com"
export BOOTSTRAP_CLOUDFLARE_APIKEY=""

# Pick a range of unused IPs that are on the same network as your nodes
# You don't need many IPs, just choose 10 IPs to start with
export BOOTSTRAP_METALLB_LB_RANGE="192.168.100.100-192.168.100.120"
# The load balancer IP for k8s_gateway, choose from one of the available IPs above
export BOOTSTRAP_METALLB_K8S_GATEWAY_ADDR="192.168.100.100"
# The load balancer IP for the ingress controller, choose from one of the available IPs above
export BOOTSTRAP_METALLB_INGRESS_ADDR="192.168.100.101"

# Age Public Key - string should start with age
export BOOTSTRAP_AGE_PUBLIC_KEY=""

# The IP Address to use with kube-vip
# Pick a unused IP that is on the same network as your nodes
# and outside the ${BOOTSTRAP_METALLB_LB_RANGE} range
export BOOTSTRAP_KUBE_VIP_ADDR="192.168.100.169"

# Choose your timezone
export BOOTSTRAP_TIMEZONE="Europe/Bucharest"

#
# Default prefixes for hostnames assigned by Ansible
# These are unused on nodes where BOOTSTRAP_ANSIBLE_HOSTNAME_ is provided
#

export BOOTSTRAP_ANSIBLE_DEFAULT_CONTROL_NODE_HOSTNAME_PREFIX="master-"
export BOOTSTRAP_ANSIBLE_DEFAULT_NODE_HOSTNAME_PREFIX="worker-"

#
# Ansible hosts - repeat this block as many times as you need,
# incrementing the last digit on the variable name for each node
#

export BOOTSTRAP_ANSIBLE_HOST_ADDR_0="192.168.100.40"
export BOOTSTRAP_ANSIBLE_SSH_USERNAME_0="david"
export BOOTSTRAP_ANSIBLE_SUDO_PASSWORD_0=""
export BOOTSTRAP_ANSIBLE_CONTROL_NODE_0="true"
export BOOTSTRAP_ANSIBLE_HOSTNAME_0="master-01"

export BOOTSTRAP_ANSIBLE_HOST_ADDR_1="192.168.100.41"
export BOOTSTRAP_ANSIBLE_SSH_USERNAME_1="david"
export BOOTSTRAP_ANSIBLE_SUDO_PASSWORD_1=""
export BOOTSTRAP_ANSIBLE_CONTROL_NODE_1="true"
export BOOTSTRAP_ANSIBLE_HOSTNAME_1="master-02"

export BOOTSTRAP_ANSIBLE_HOST_ADDR_2="192.168.100.42"
export BOOTSTRAP_ANSIBLE_SSH_USERNAME_2="david"
export BOOTSTRAP_ANSIBLE_SUDO_PASSWORD_2=""
export BOOTSTRAP_ANSIBLE_CONTROL_NODE_2="true"
export BOOTSTRAP_ANSIBLE_HOSTNAME_2="master-03"

export BOOTSTRAP_ANSIBLE_HOST_ADDR_3="192.168.100.43"
export BOOTSTRAP_ANSIBLE_SSH_USERNAME_3="david"
export BOOTSTRAP_ANSIBLE_SUDO_PASSWORD_3=""
export BOOTSTRAP_ANSIBLE_CONTROL_NODE_3="false"
export BOOTSTRAP_ANSIBLE_HOSTNAME_3="worker-01"

export BOOTSTRAP_ANSIBLE_HOST_ADDR_4="192.168.100.44"
export BOOTSTRAP_ANSIBLE_SSH_USERNAME_4="david"
export BOOTSTRAP_ANSIBLE_SUDO_PASSWORD_4=""
export BOOTSTRAP_ANSIBLE_CONTROL_NODE_4="false"
export BOOTSTRAP_ANSIBLE_HOSTNAME_4="worker-02"

export BOOTSTRAP_ANSIBLE_HOST_ADDR_5="192.168.100.45"
export BOOTSTRAP_ANSIBLE_SSH_USERNAME_5="david"
export BOOTSTRAP_ANSIBLE_SUDO_PASSWORD_5=""
export BOOTSTRAP_ANSIBLE_CONTROL_NODE_5="false"
export BOOTSTRAP_ANSIBLE_HOSTNAME_5="worker-03"
